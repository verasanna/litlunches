---
import type { Props } from '@astrojs/starlight/props';
//import type { StarlightRouteData } from '@astrojs/starlight/route-data';
import Pagination from '@astrojs/starlight/components/Pagination.astro';

const year = new Date().getFullYear();
---
<Pagination /> 

<footer class="custom-footer">
  <div class="custom-footer__inner">
    <p class="custom-footer__copy">© {year} Litlunches</p>
    <nav class="custom-footer__nav" aria-label="Footer">
      <a href="/blog/">Blog</a>
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
      <a href="/legal/">Legal</a>
      <a href="/rss.xml" class="rss-link" aria-label="Blog RSS feed" title="Blog RSS feed">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
        </svg>
        Blog
      </a>
      <a href="/docs-rss.xml" class="rss-link" aria-label="Book lists RSS feed" title="Book lists RSS feed">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
        </svg>
        Books
      </a>
    </nav>
  </div>
</footer>

<style>
  .custom-footer {
    border-top: 1px solid var(--sl-color-hairline);
    padding: 1.5rem var(--sl-content-pad-x);
    margin-top: auto;
  }

  .custom-footer__inner {
    max-width: var(--sl-content-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.875rem;
  }

  .custom-footer__copy {
    margin: 0;
    color: var(--sl-color-gray-3);
  }

  .custom-footer__nav {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .custom-footer__nav a {
    color: var(--sl-color-gray-3);
    text-decoration: none;
  }

  .custom-footer__nav a:hover {
    color: var(--sl-color-white);
  }

  .rss-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
</style>
