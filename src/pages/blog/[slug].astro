---
import { getCollection, render } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const siteUrl = 'https://litlunches.space';
const ogImage = post.data.image
  ? `${siteUrl}${post.data.image}`
  : `${siteUrl}/og-default.jpg`;
---

<StarlightPage
  frontmatter={{
    title: post.data.title,
    description: post.data.description,
    head: [
      {
        tag: 'meta',
        attrs: { property: 'og:title', content: post.data.title },
      },
      {
        tag: 'meta',
        attrs: { property: 'og:description', content: post.data.description },
      },
      {
        tag: 'meta',
        attrs: { property: 'og:image', content: ogImage },
      },
      {
        tag: 'meta',
        attrs: { property: 'og:type', content: 'article' },
      },
      {
        tag: 'meta',
        attrs: { name: 'twitter:card', content: 'summary_large_image' },
      },
      {
        tag: 'meta',
        attrs: { name: 'twitter:title', content: post.data.title },
      },
      {
        tag: 'meta',
        attrs: { name: 'twitter:description', content: post.data.description },
      },
      {
        tag: 'meta',
        attrs: { name: 'twitter:image', content: ogImage },
      },
      {
        tag: 'script',
        attrs: { type: 'application/ld+json' },
        content: JSON.stringify({
          '@context': 'https://schema.org',
          '@type': 'BlogPosting',
          headline: post.data.title,
          description: post.data.description,
          image: ogImage,
          datePublished: post.data.pubDate.toISOString(),
          url: `${siteUrl}/blog/${post.id}`,
          author: {
            '@type': 'Organization',
            name: 'Litlunches',
            url: siteUrl,
          },
        }),
      },
    ],
  }}
  headings={headings}
>
  <p style="color: var(--sl-color-gray-3); font-size: 0.875rem; margin-top: 0;">
    {post.data.pubDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })}
  </p>

  {post.data.image && (
    <img
      src={post.data.image}
      alt={post.data.title}
      style="width: 100%; border-radius: 8px; margin-bottom: 2rem;"
    />
  )}

  <Content />
</StarlightPage>