---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const isRecipe = post.data.type === 'recipe';
---

<PageLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
  schema={isRecipe ? 'Recipe' : 'BlogPosting'}
  pubDate={post.data.pubDate}
  headings={headings}
  recipe={isRecipe ? {
    prepTime: post.data.prepTime,
    cookTime: post.data.cookTime,
    recipeYield: post.data.recipeYield,
    recipeCategory: post.data.recipeCategory,
    recipeCuisine: post.data.recipeCuisine,
    ingredients: post.data.ingredients,
    instructions: post.data.instructions,
  } : undefined}
>
  <p style="color: var(--sl-color-gray-3); font-size: 0.875rem; margin-top: 0;">
    {post.data.pubDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })}
  </p>

  {post.data.image && (
    <img
      src={post.data.image}
      alt={post.data.title}
      style="width: 100%; border-radius: 8px; margin-bottom: 2rem;"
    />
  )}

  <Content />
</PageLayout>