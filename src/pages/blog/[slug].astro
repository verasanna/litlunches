---
import { getCollection, render } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );

  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[i + 1] ?? null,  // older post (further down the sorted list)
      next: posts[i - 1] ?? null,  // newer post (further up the sorted list)
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);

const isRecipe = post.data.type === 'recipe';
---

<PageLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
  schema={isRecipe ? 'Recipe' : 'BlogPosting'}
  pubDate={post.data.pubDate}
  headings={headings}
  recipe={isRecipe ? {
    prepTime: post.data.prepTime,
    cookTime: post.data.cookTime,
    recipeYield: post.data.recipeYield,
    recipeCategory: post.data.recipeCategory,
    recipeCuisine: post.data.recipeCuisine,
    ingredients: post.data.ingredients,
    instructions: post.data.instructions,
  } : undefined}
>
  <p style="color: var(--sl-color-gray-3); font-size: 0.875rem; margin-top: 0;">
    {post.data.pubDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })}
  </p>

  {post.data.image && (
    <img
      src={post.data.image}
      alt={post.data.title}
      style="width: 100%; border-radius: 8px; margin-bottom: 2rem;"
    />
  )}

  <Content />

  <!-- Starlight-matching pagination -->
  {(prev || next) && (
    <nav aria-label="Next and previous links" class="pagination-links">
      {prev && (
        <a href={`/blog/${prev.id}/`} rel="prev" class="link">
          <svg aria-hidden="true" class="link-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17 11H9.41l3.3-3.29a1 1 0 1 0-1.42-1.42l-5 5a1 1 0 0 0 0 1.42l5 5a1 1 0 0 0 1.42 0 1 1 0 0 0 0-1.42L9.41 13H17a1 1 0 0 0 0-2Z"/>
          </svg>
          <span class="link-content">
            <span class="label">Previous</span>
            <span class="title">{prev.data.title}</span>
          </span>
        </a>
      )}
      {next && (
        <a href={`/blog/${next.id}/`} rel="next" class="link link--next">
          <span class="link-content">
            <span class="label">Next</span>
            <span class="title">{next.data.title}</span>
          </span>
          <svg aria-hidden="true" class="link-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.92 11.62a1 1 0 0 0-.21-.33l-5-5a1 1 0 0 0-1.42 1.42l3.3 3.29H7a1 1 0 0 0 0 2h7.59l-3.3 3.29a1 1 0 0 0 1.42 1.42l5-5a1 1 0 0 0 .21-1.09Z"/>
          </svg>
        </a>
      )}
    </nav>
  )}
</PageLayout>

<style>
  .pagination-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--sl-color-white);
    flex-basis: calc(50% - 0.5rem);
    flex-grow: 1;
    transition: border-color 0.2s ease;
  }

  .link:hover {
    border-color: var(--sl-color-gray-2);
  }

  .link--next {
    justify-content: flex-end;
    text-align: end;
  }

  .link-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .label {
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-3);
    line-height: 1;
  }

  .title {
    font-size: var(--sl-text-base);
    font-weight: 600;
    line-height: 1.25;
    color: var(--sl-color-white);
  }

  .link-icon {
    flex-shrink: 0;
    color: var(--sl-color-gray-3);
  }
</style>
