---
import PageLayout from '../layouts/PageLayout.astro';
import { site } from '../config/site';
---

<PageLayout
  title="Contact"
  description="Get in touch with Litlunches"
  schema="ContactPage"
>
  <p>Have a suggestion for a book, a correction, or just want to say hello?</p>
  <p>
    Send an email to{' '}
    <a href="mailto:info@litlunches.space">info@litlunches.space</a>.
  </p>
  <p>Or find us on </p>
    <p>
    <a href={site.social.facebook} style="display: inline-flex; align-items: center; gap: 0.4rem;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M24 12.073C24 5.404 18.627 0 12 0S0 5.404 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
      </svg>
      Facebook
    </a>
  </p>
</PageLayout>